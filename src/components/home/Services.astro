---
const services = [
  {
    step: '01',
    name: 'Responsible & explainable AI for health',
    description:
      'Evaluation for trust in real settings: interpretability, robustness, and fairness across groups.',
  },
  {
    step: '02',
    name: 'Clinical prediction & preventive health modelling',
    description:
      'Risk prediction using clinical and population data, with validation designed for real-world use.',
  },
  {
    step: '03',
    name: 'Reproducible ML pipelines',
    description:
      'End-to-end, reusable modelling workflows that make analyses easier to audit, maintain, and extend.',
  },
];
---


<section id="work" class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-12 sm:gap-16">
      <h2 class="font-signature italic font-semibold tracking-tight text-3xl sm:text-4xl lg:text-5xl leading-[0.95]">
        What I do
      </h2>

      <div class="grid gap-8 lg:grid-cols-3">
        {
          services.map((service) => (
            <div class="bg-primary-500/10 dark:bg-primary-400/10 flex flex-col gap-12 rounded-3xl px-6 py-8">
              <p class="text-sm">{service.step}</p>

              <div class="flex flex-col gap-4">
                <h3 class="text-xl font-medium">{service.name}</h3>
                <p class="text-primary-950/70 dark:text-primary-200/70 text-base sm:text-lg">
                  {service.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
