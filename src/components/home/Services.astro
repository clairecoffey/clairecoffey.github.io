---
const services = [
  {
    step: '01',
    name: 'Responsible AI for preventive health',
    description:
      'Trustworthy, interpretable, and fair AI systems designed for real-world health use.',
  },
  {
    step: '02',
    name: 'Personalised prevention',
    description:
      'Turning biomarker, wearable, and health data into more actionable and individualised prevention.',
  },
  {
    step: '03',
    name: 'Research translation into product',
    description:
      'Bridging rigorous health data science with practical tools that people and providers can actually use.',
  },
];
---


<section id="work" class="py-16 sm:py-20">
  <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
    <div class="flex flex-col gap-12 sm:gap-16">
      <h2 class="font-signature italic font-semibold tracking-tight text-3xl sm:text-4xl lg:text-5xl leading-[0.95]">
        What I do
      </h2>

      <div class="grid gap-8 lg:grid-cols-3">
        {
          services.map((service) => (
            <div class="bg-primary-500/10 dark:bg-primary-400/10 flex flex-col gap-12 rounded-3xl px-6 py-8">
              <p class="text-sm">{service.step}</p>

              <div class="flex flex-col gap-4">
                <h3 class="text-xl font-medium">{service.name}</h3>
                <p class="text-primary-950/70 dark:text-primary-200/70 text-base sm:text-lg">
                  {service.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
